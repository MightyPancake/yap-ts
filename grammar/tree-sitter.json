{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "yap",
      "camelcase": "Yap",
      "title": "Yap",
      "scope": "source.yap",
      "file-types": [
        "yap"
      ],
      "injection-regex": "^yap$",
      "class-name": "TreeSitterYap"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Yap grammar for tree-sitter",
    "authors": [
      {
        "name": "Filip Król"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-yap"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}